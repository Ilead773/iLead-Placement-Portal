# Production environment variables — baked into the JS bundle at build time.
# On Railway: set VITE_API_URL in the frontend service's environment variables
# and Railway will pass it as a Docker build ARG automatically.
VITE_API_URL=https://your-backend.up.railway.app/api/v1
VITE_APP_NAME=iLEAD Placement Portal
VITE_DEBUG=false
VITE_LOG_LEVEL=error
