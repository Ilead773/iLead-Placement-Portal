# ─── Django Core ──────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=your-secret-key-change-in-production-50-chars-random

# Comma-separated list of allowed host domains (include your Railway domain)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,your-backend.up.railway.app

# ─── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string (auto-injected by Railway if you add a Postgres plugin)
DATABASE_URL=postgresql://user:password@localhost:5432/ilead_db
# SQLite for local dev only:
# DATABASE_URL=sqlite:///db.sqlite3

# ─── Redis ─────────────────────────────────────────────────────────
# Redis connection string (auto-injected by Railway if you add a Redis plugin)
REDIS_URL=redis://localhost:6379/0

# ─── CORS / Frontend ───────────────────────────────────────────────
# Comma-separated list of exact frontend origin URLs
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend.up.railway.app
FRONTEND_URL=https://your-frontend.up.railway.app

# ─── Celery ────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set to True ONLY for testing to run tasks synchronously
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=False

# ─── Email (choose one backend) ────────────────────────────────────
# Options:
#   core.email_backends.BrevoEmailBackend   (Brevo/Sendinblue API)
#   core.email_backends.ResendEmailBackend  (Resend API)
#   django.core.mail.backends.smtp.EmailBackend (SMTP)
EMAIL_BACKEND=core.email_backends.BrevoEmailBackend

# Brevo (Sendinblue) API
BREVO_API_KEY=your_brevo_api_key_here
BREVO_TEST_MODE=True
BREVO_TEST_REDIRECT_EMAIL=admin@example.com

# Resend API
RESEND_API_KEY=your_resend_api_key_here
RESEND_TEST_MODE=True
RESEND_TEST_REDIRECT_EMAIL=admin@example.com

# SMTP (fallback if no API key set)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_smtp_username_here
EMAIL_HOST_PASSWORD=your_smtp_password_here

DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ─── AWS S3 (Optional — for media/resume PDF storage) ──────────────
STORAGE_BACKEND=local
# Set to 's3' and configure below to use S3:
# STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# ─── JWT ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# ─── AI Features ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Job Scraper API Keys (optional) ────────────────────────────────
JSEARCH_API_KEY=
APIFY_API_TOKEN=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ─── Admin Panel ────────────────────────────────────────────────────
DJANGO_ADMIN_URL=admin-secure-portal/
# Restrict admin to specific IPs (comma-separated). Leave blank to allow all.
ADMIN_IP_WHITELIST=
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123

# ─── Resume Engine Limits (optional overrides) ───────────────────────
MAX_BUILT_RESUMES=5
MAX_UPLOADED_RESUMES=5
MAX_RESUME_UPLOAD_SIZE=5242880
MAX_PROFILE_PICTURE_SIZE=2097152

# ─── Error Monitoring (optional) ─────────────────────────────────────
SENTRY_DSN=

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
