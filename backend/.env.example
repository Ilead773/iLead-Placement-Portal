# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DATABASE_URL=sqlite:///db.sqlite3
# Or PostgreSQL: postgresql://user:password@localhost:5432/ilead_db

# Redis (for Celery & Caching)
REDIS_URL=redis://localhost:6379/0

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email Configuration
# By default the project uses Resend (core.email_backends.ResendEmailBackend).
# To use SMTP, set `EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend`
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_smtp_username_here
EMAIL_HOST_PASSWORD=your_smtp_password_here
DEFAULT_FROM_EMAIL=onboarding@example.com

# AWS S3 (Optional - for media storage)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OpenAI API Key (for AI features)
OPENAI_API_KEY=sk-your-api-key

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123
ADMIN_EMAIL=admin@ileadportal.com

# Logging
LOG_LEVEL=INFO

# OneSignal Configuration
ONESIGNAL_APP_ID=97a17b7a-8d2b-4daf-bba5-a0b16d31a1bb
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key_here

